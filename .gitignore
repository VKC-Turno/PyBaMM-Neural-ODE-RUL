!outputs/holdout_sweep/

# ── Python ──
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.env

# ── LaTeX aux ──
paper/*.aux
paper/*.log
paper/*.out
paper/*.fls
paper/*.fdb_latexmk
paper/*.synctex.gz

# ── Editor / OS ──
.vscode/
.idea/
.DS_Store
*.swp

# ── Notebooks ──
.ipynb_checkpoints/
